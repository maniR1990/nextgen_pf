{
  "name": "nextgen-pf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/ensure-db.ts && next dev",
    "build": "prisma generate && next build",
    "start": "tsx scripts/ensure-db.ts && next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "storybook:build": "storybook build --disable-telemetry",
    "chromatic": "chromatic --exit-zero-on-changes",
    "chromatic:ci": "chromatic --exit-zero-on-changes",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:sync": "prisma generate && prisma db push",
    "db:ensure": "tsx scripts/ensure-db.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:fix-ids": "tsx scripts/fix-account-ids.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@prisma/client": "^6.9.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@tremor/react": "^3.18.7",
    "bcryptjs": "^3.0.2",
    "currency.js": "^2.0.4",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.21",
    "decimal.js": "^10.6.0",
    "dinero.js": "^2.0.2",
    "geist": "^1.7.2",
    "jose": "^6.0.11",
    "json-rules-engine": "^7.3.1",
    "lightweight-charts": "^4.2.3",
    "lucide-react": "^1.17.0",
    "luxon": "^3.7.2",
    "next": "^15.3.3",
    "next-auth": "^4.24.11",
    "pino": "^9.7.0",
    "react": "^19.1.0",
    "react-chrono": "^3.3.3",
    "react-dom": "^19.1.0",
    "react-vertical-timeline-component": "^4.0.0",
    "recharts": "^2.15.4",
    "swr": "^2.3.3",
    "zod": "^3.25.56",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@chromatic-com/storybook": "^4.0.0",
    "@playwright/test": "^1.52.0",
    "@storybook/addon-docs": "^9.1.7",
    "@storybook/nextjs-vite": "^9.1.7",
    "@storybook/react": "^9.1.7",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/react-vertical-timeline-component": "^3.3.6",
    "@vitejs/plugin-react": "^4.5.0",
    "axe-core": "^4.10.3",
    "chromatic": "^13.0.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "msw": "^2.8.7",
    "msw-storybook-addon": "^2.0.4",
    "nx": "^21.1.3",
    "oxfmt": "^0.8.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.9.0",
    "sass": "^1.89.2",
    "storybook": "^9.1.7",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.4"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "msw": {
    "workerDirectory": ["public"]
  }
}
