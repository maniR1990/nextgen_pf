# Database — local MongoDB (default for dev)
DATABASE_URL="mongodb://127.0.0.1:27017/nextgen-pf"

# Dev: auto db push on pnpm dev / pnpm start (set false to connect only)
DB_SYNC_ON_START="true"

# Database — MongoDB Atlas (production / Vercel)
# DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nextgen-pf?retryWrites=true&w=majority"

# JWT (falls back to NEXTAUTH_SECRET if unset)
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# NextAuth + OAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Show OAuth buttons in login/register UI when credentials are configured
NEXT_PUBLIC_OAUTH_GOOGLE="false"
NEXT_PUBLIC_OAUTH_GITHUB="false"

# Personal deploy — skip email verification (recommended for Vercel + Atlas only)
AUTO_VERIFY_EMAIL="true"

# Weekly token cleanup (Vercel Cron — Pro plan)
CRON_SECRET="change-me-in-production"

# Logging — pino (default) | console | json
LOGGER_PROVIDER="pino"
LOG_LEVEL="info"
LOGGER_PRETTY="true"

# Feature flag env overrides (optional)
# FLAG_NEW_DASHBOARD=true

# Chromatic (CI only)
# CHROMATIC_PROJECT_TOKEN=
